pipeline {

    agent any

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/assumptagithub/wordpress-devops.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t wordpress-devops .'
            }
        }

        stage('Stop Old Container (if any)') {
            steps {
                sh 'docker rm -f wordpress-live || true'
            }
        }

        stage('Deploy Application') {
            steps {
                sh 'docker run -d -p 8082:80 --name wordpress-live wordpress-devops'
            }
        }

        stage('Wait for App') {
            steps {
                sh 'sleep 20'
            }
        }

        stage('Test Application') {
            steps {
                sh 'curl -I http://localhost:8082'
            }
        }

    }
}
